<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<!-- Default account at ~/.claude is covered by this static exception
		     (no bookmark needed). Additional CLAUDE_CONFIG_DIRs picked by the
		     user in the Accounts settings pane are accessed via
		     security-scoped bookmarks (see user-selected.read-only below). -->
		<string>/.claude/claudewatch-usage.json</string>
	</array>
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<key>com.apple.security.files.bookmarks.app-scope</key>
	<true/>
</dict>
</plist>
