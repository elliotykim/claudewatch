<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<!-- Narrowed from /.claude/ (whole directory) to the single file the
		     app actually reads. QuotaSyncClient.swift only calls
		     FileManager.default.contents(atPath:) on this exact path, so the
		     directory-wide exception was broader than necessary. -->
		<string>/.claude/claudewatch-usage.json</string>
	</array>
</dict>
</plist>
